      "task": "Analyze and understand the local and national implications of proposed legislation.",
      "task_type": "Unclassified"
    },
    {
      "task": "Appoint nominees to leadership posts, or approve such appointments.",
      "task_type": "Unclassified"
    },
    {
      "task": "Represent their government at local, national, and international meetings and conferences.",
      "task_type": "Unclassified"
    },
    {
      "task": "Promote the industries and products of their electoral districts.",
      "task_type": "Unclassified"
    },
    {
      "task": "Organize and maintain campaign organizations and fundraisers to raise money for election or re-election.",
      "task_type": "Unclassified"
    },
    {
      "task": "Evaluate the structure, efficiency, activities, and performance of government agencies.",
      "task_type": "Unclassified"
    },
    {
      "task": "Establish personal offices in local districts or states and manage office staff.",
      "task_type": "Unclassified"
    },
    {
      "task": "Encourage and support party candidates for political office.",
      "task_type": "Unclassified"
    },
    {
      "task": "Determine campaign strategies for media advertising and public appearances.",
      "task_type": "Unclassified"
    },
    {
      "task": "Conduct 'head counts' to help predict the outcome of upcoming votes.",
      "task_type": "Unclassified"
    },
    {
      "task": "Attend receptions and conferences to meet people and develop working relationships.",
      "task_type": "Unclassified"
    },
    {
      "task": "Alert constituents of government actions and programs through newsletters and personal appearances.",
      "task_type": "Unclassified"
    },
    {
      "task": "Vote on motions, amendments, and decisions regarding bills in committees.",
      "task_type": "Unclassified"
    },
    {
      "task": "Serve on commissions and committees to recommend action on specialized areas.",
      "task_type": "Unclassified"
    },
    {
      "task": "Seek government funding for local projects and programs.",
      "task_type": "Unclassified"
    },
    {
      "task": "Review concerns of constituents and determine if governmental action is necessary.",
      "task_type": "Unclassified"
    },
    {
      "task": "Prepare drafts of amendments, government policies, laws, budgets, and procedures.",
      "task_type": "Unclassified"
    },
    {
      "task": "Negotiate with colleagues to reconcile differing interests and create policies.",
      "task_type": "Unclassified"
    },
    {
      "task": "Maintain knowledge of relevant national and international current events.",
      "task_type": "Unclassified"
    },
    {
      "task": "Keep abreast of issues affecting constituents through various outreach efforts.",
      "task_type": "Unclassified"
    },
    {
      "task": "Hear testimony from constituents and other interested parties regarding bills under consideration.",
      "task_type": "Unclassified"
    },
    {
      "task": "Debate the merits of proposals and bill amendments during floor sessions.",
      "task_type": "Unclassified"
    },
    {
      "task": "Confer with colleagues to formulate positions on pending issues.",
      "task_type": "Unclassified"
    },
    {
      "task": "Speak to students to encourage the development of future political leaders.",
      "task_type": "Unclassified"
    }
